әР РҶР вҖҡРІРӮСҡР В Р’В Р вҖҷР’В Р В РІРӮв„ўР вҖҷР’В Р В Р’В Р РҶР вҖҡРІвҖһСһР В РІРӮв„ўР вҖҷР’В Р В Р’В Р вҖҷР’В Р В Р вҖ Р В РІРӮСҷР РҶРІРӮСӣРЎСӣР В Р’В Р РҶР вҖҡРІвҖһСһР В РІРӮв„ўР вҖҷР’В Р В Р’В Р вҖҷР’В Р В РІРӮв„ўР вҖҷР’В Р В Р’В Р РҶР вҖҡРІвҖһСһР В РІРӮв„ўР вҖҷР’В Р В Р’В Р вҖҷР’В Р В РІРӮв„ўР вҖҷР’В Р В Р’В Р вҖҷР’В Р В Р’В Р В Р РҸ NeuroPro AI

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(USER)
  status        String    @default("Active")
  privileges    Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  purchases      Purchase[]
  certificates   Certificate[]
  bookmarks      Bookmark[]
  assignments    Assignment[]
  quizAttempts   QuizAttempt[]
  referral       Referral?
  subscription   Subscription?
  reviews        Review[]
  notifications  Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  amount    Float
  status        String    @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

enum CourseCategory {
  BEGINNER
  AUTOMATION
  AI_BUSINESS
  ADVANCED
}

model Course {
  id             String         @id @default(cuid())
  slug           String         @unique
  title          String
  description    String
  price          String
  duration       String
  level          CourseCategory
  modules        Json
  detailedModules Json
  outcomes       Json
  whatIncluded   Json
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model TgPayment {
  id        String   @id
  title     String
  price     String
  status    String
  due       String
  createdAt DateTime @default(now())
}

model TgActivity {
  id        String   @id
  title     String
  time      String
  meta      String
  createdAt DateTime @default(now())
}

model TgUser {
  id          String   @id @default(cuid())
  telegramId  String   @unique
  name        String
  role        String
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchases   TgPurchase[]
  progress    TgCourseProgress[]
}

model TgPurchase {
  id          String   @id @default(cuid())
  tgUserId    String
  courseSlug  String
  status      String
  price       String
  purchasedAt DateTime @default(now())

  user TgUser @relation(fields: [tgUserId], references: [id], onDelete: Cascade)

  @@unique([tgUserId, courseSlug])
}

model TgCourseProgress {
  id         String   @id @default(cuid())
  tgUserId   String
  courseSlug String
  progress   Int
  nextLesson String
  updatedAt  DateTime @updatedAt

  user TgUser @relation(fields: [tgUserId], references: [id], onDelete: Cascade)

  @@unique([tgUserId, courseSlug])
}

// РўСҖРөРәРёРҪРі РҝСҖРҫРіСҖРөСҒСҒР° СғСҖРҫРәРҫРІ
model LessonProgress {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  moduleId  Int
  lessonId  Int
  completed Boolean  @default(false)
  completedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId, moduleId, lessonId])
  @@index([userId, courseId])
}

// Р’РёРҙРөРҫ РҙР»СҸ СғСҖРҫРәРҫРІ
model Video {
  id        String   @id @default(cuid())
  courseId  String
  moduleId  Int
  lessonId  Int
  title     String
  videoUrl  String   // YouTube/Vimeo URL РёР»Рё РҝСғСӮСҢ Рә С„Р°Р№Р»Сғ
  duration  Int?     // РҙР»РёСӮРөР»СҢРҪРҫСҒСӮСҢ РІ СҒРөРәСғРҪРҙР°С…
  provider  String   @default("youtube") // youtube, vimeo, local
  videoId   String?  // ID РІРёРҙРөРҫ РҙР»СҸ embed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
  @@unique([courseId, moduleId, lessonId])
}

// РЎРөСҖСӮРёС„РёРәР°СӮСӢ
model Certificate {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  certificateUrl String?
  certificateId String @unique
  issuedAt  DateTime @default(now())
  studentName String
  courseName String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

// Р—Р°РәР»Р°РҙРәРё
model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  moduleId  Int
  lessonId  Int
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, moduleId, lessonId])
  @@index([userId])
}

// Р”РҫРјР°СҲРҪРёРө Р·Р°РҙР°РҪРёСҸ
model Assignment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  moduleId  Int
  lessonId  Int
  content   String
  status    String   @default("pending") // pending, submitted, reviewed, rejected
  feedback  String?
  submittedAt DateTime?
  reviewedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

// РўРөСҒСӮСӢ/РәРІРёР·СӢ
model Quiz {
  id        String   @id @default(cuid())
  courseId  String
  moduleId  Int
  title     String
  questions Json  // [{question, options, correct}]
  createdAt DateTime @default(now())

  attempts QuizAttempt[]
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  answers   Json    // [selected options]
  score     Float   // 0-100
  createdAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// РҹСҖРҫРјРҫРәРҫРҙСӢ
model PromoCode {
  id        String   @id @default(cuid())
  code      String   @unique
  discount  Float    // РҝСҖРҫСҶРөРҪСӮ СҒРәРёРҙРәРё
  maxUses   Int?
  usedCount Int      @default(0)
  expiresAt DateTime?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Р РөС„РөСҖР°Р»СҢРҪСӢРө СҒСҒСӢР»РәРё
model Referral {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  uses      Int      @default(0)
  earnings  Float    @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// РҹРҫРҙРҝРёСҒРәРё
model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  plan      String   // starter, pro, business
  status    String   @default("active")
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// РһСӮР·СӢРІСӢ
model Review {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
}

// РЈРІРөРҙРҫРјР»РөРҪРёСҸ
model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // course, payment, system
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}
