generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(USER)
  status        String    @default("Active")
  privileges    Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  purchases     Purchase[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

model Purchase {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  amount    Float
  status        String    @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

enum CourseCategory {
  BEGINNER
  AUTOMATION
  AI_BUSINESS
  ADVANCED
}

model Course {
  id             String         @id @default(cuid())
  slug           String         @unique
  title          String
  description    String
  price          String
  duration       String
  level          CourseCategory
  modules        Json
  detailedModules Json
  outcomes       Json
  whatIncluded   Json
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model TgPayment {
  id        String   @id
  title     String
  price     String
  status    String
  due       String
  createdAt DateTime @default(now())
}

model TgActivity {
  id        String   @id
  title     String
  time      String
  meta      String
  createdAt DateTime @default(now())
}

model TgUser {
  id          String   @id @default(cuid())
  telegramId  String   @unique
  name        String
  role        String
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchases   TgPurchase[]
  progress    TgCourseProgress[]
}

model TgPurchase {
  id          String   @id @default(cuid())
  tgUserId    String
  courseSlug  String
  status      String
  price       String
  purchasedAt DateTime @default(now())

  user TgUser @relation(fields: [tgUserId], references: [id], onDelete: Cascade)

  @@unique([tgUserId, courseSlug])
}

model TgCourseProgress {
  id         String   @id @default(cuid())
  tgUserId   String
  courseSlug String
  progress   Int
  nextLesson String
  updatedAt  DateTime @updatedAt

  user TgUser @relation(fields: [tgUserId], references: [id], onDelete: Cascade)

  @@unique([tgUserId, courseSlug])
}
